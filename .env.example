# ==============================================
# Valoración de Puestos MSC — Variables de Entorno
# ==============================================
# Copiar este archivo a .env y completar los valores

# ---- Base de Datos (PostgreSQL / Neon) ----
DATABASE_URL=postgresql://user:password@host:5432/valoracion_puestos_msc_db

# ---- Supabase (Catálogo de puestos - solo lectura) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- AI Agent (Ollama local) ----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2:latest

# ---- Server ----
PORT=5000
NODE_ENV=development
